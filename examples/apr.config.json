{
  "version": 1,
  "build": {
    "task": ":app:assembleDebug"
  },
  "artifact": {
    "target": "app",
    "variant": "debug"
  },
  "run": {
    "packageName": "com.example.app",
    "activity": ".MainActivity"
  },
  "idle": {
    "pollIntervalMs": 200,
    "stablePolls": 2,
    "timeoutMs": 5000
  },
  "artifactsDir": ".apr/runs"
}
