{
  "version": 1,
  "name": "TapHound demo search",
  "steps": [
    {
      "action": "click",
      "locator": {
        "resourceId": "open_search"
      },
      "activity": {
        "before": "dev.taphound.demo.MainActivity",
        "after": "dev.taphound.demo.SearchActivity"
      },
      "expect": {
        "type": "element",
        "locator": {
          "resourceId": "search_input"
        },
        "timeoutMs": 3000
      }
    },
    {
      "action": "click",
      "locator": {
        "resourceId": "search_input"
      },
      "activity": {
        "before": "dev.taphound.demo.SearchActivity",
        "after": "dev.taphound.demo.SearchActivity"
      }
    },
    {
      "action": "inputText",
      "text": "hello world",
      "activity": {
        "before": "dev.taphound.demo.SearchActivity",
        "after": "dev.taphound.demo.SearchActivity"
      }
    },
    {
      "action": "click",
      "locator": {
        "resourceId": "submit_search"
      },
      "activity": {
        "before": "dev.taphound.demo.SearchActivity",
        "after": "dev.taphound.demo.SearchActivity"
      },
      "expect": {
        "type": "logcat",
        "tag": "SearchViewModel",
        "level": "I",
        "pattern": "submitted query=hello world",
        "match": "literal",
        "timeoutMs": 3000
      }
    }
  ]
}
