{
  "name": "taphound",
  "version": "0.2.0-dev.1",
  "description": "Deterministic app journey recording and verification",
  "type": "module",
  "bin": {
    "taphound": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "acceptance:device": "node scripts/acceptance-device.mjs",
    "build": "tsc -p tsconfig.build.json",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
