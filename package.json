{
  "name": "taphound",
  "version": "0.2.0-dev.1",
  "description": "Deterministic app journey recording and verification",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caikaidev/TapHound.git"
  },
  "bugs": {
    "url": "https://github.com/caikaidev/TapHound/issues"
  },
  "homepage": "https://github.com/caikaidev/TapHound#readme",
  "keywords": [
    "android",
    "testing",
    "regression-testing",
    "journey",
    "cli",
    "ai-agent"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "dev"
  },
  "type": "module",
  "bin": {
    "taphound": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "assets/brand/taphound-mark.svg"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "acceptance:device": "node scripts/acceptance-device.mjs",
    "brand:render": "node scripts/render-brand-assets.mjs",
    "build": "tsc -p tsconfig.build.json",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
